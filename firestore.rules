rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/admins/$(request.auth.token.email));
    }

    match /admins/{email} {
      allow read:  if request.auth != null;
      allow write: if false;
    }

    match /quizzes/{quizId} {
      allow read:  if request.auth != null;
      allow write: if isAdmin();

      match /data/{doc} {
        allow read:  if request.auth != null;
        allow write: if isAdmin();
      }
    }

    // Allow admins to LIST the quizSessions collection (needed to enumerate all UIDs)
    match /quizSessions/{uid} {
      allow read, write: if (request.auth != null && request.auth.uid == uid)
                         || isAdmin();
    }

    // Allow users to read/write their own subcollection data; admins can read/write all
    match /quizSessions/{uid}/{document=**} {
      allow read, write: if (request.auth != null && request.auth.uid == uid)
                         || isAdmin();
    }
  }
}
