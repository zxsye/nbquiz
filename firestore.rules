rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/admins/$(request.auth.token.email));
    }

    match /admins/{email} {
      allow read:  if request.auth != null;
      allow write: if false;
    }

    match /quizzes/{quizId} {
      allow read:  if request.auth != null;
      allow write: if isAdmin();

      match /data/{doc} {
        allow read:  if request.auth != null;
        allow write: if isAdmin();
      }
    }

    // Week-level parent pills (semantic clusters of per-quiz AI topic pills)
    match /weekParentPills/{docId} {
      allow read:  if request.auth != null;
      allow write: if isAdmin();
    }

    // Each user can access their own session data; admins can access all
    match /quizSessions/{uid} {
      allow read, write: if (request.auth != null && request.auth.uid == uid)
                         || isAdmin();
    }
    match /quizSessions/{uid}/{document=**} {
      allow read, write: if (request.auth != null && request.auth.uid == uid)
                         || isAdmin();
    }

    // Collection group rules — required for collectionGroup() queries by admins.
    // These let admins query across ALL "quizzes" and "notes" subcollections
    // regardless of where they sit in the hierarchy.
    match /{path=**}/quizzes/{docId} {
      allow read, write: if isAdmin();
    }
    match /{path=**}/notes/{docId} {
      allow read, write: if isAdmin();
    }

    // PromptMX / Study OS — catalog (templates, workflow, sections)
    match /pmx_sections/{docId} {
      allow read:  if request.auth != null;
      allow write: if isAdmin();
    }
    match /pmx_promptTemplates/{docId} {
      allow read:  if request.auth != null;
      allow write: if isAdmin();
    }
    match /pmx_workflowStepTypes/{docId} {
      allow read:  if request.auth != null;
      allow write: if isAdmin();
    }
    match /pmx_workflowDefinitions/{docId} {
      allow read:  if request.auth != null;
      allow write: if isAdmin();
    }
    match /pmx_weekMasterData/{docId} {
      allow read:  if request.auth != null;
      allow write: if isAdmin();
    }

    // PromptMX — per-user Study OS state (single doc per uid)
    match /pmx_userStudyOsState/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
